# ══════════════════════════════════════════
# SERVEUR
# ══════════════════════════════════════════
NODE_ENV=development
# DB_SYNC_ALTER=true  # Déconseillé : sync Sequelize alter (lourd). Utiliser les migrations SQL.
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
MOBILE_DEEP_LINK=medicarebi://

# ══════════════════════════════════════════
# BASE DE DONNÉES PostgreSQL
# ══════════════════════════════════════════
DATABASE_URL=postgresql://postgres:motdepasse@db.xxxxx.supabase.co:5432/postgres

DB_POOL_MAX=10
DB_POOL_MIN=2
DB_SYNC_ALTER=false
DB_SYNC=true

# ══════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ══════════════════════════════════════════
# JWT
# ══════════════════════════════════════════
JWT_SECRET=your_very_long_secret_key_here_minimum_64_characters_required
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_different_from_access_jwt_secret
JWT_REFRESH_EXPIRES_IN=7d
QR_SECRET=your_qr_specific_secret_key_for_qr_codes

# ══════════════════════════════════════════
# BCRYPT
# ══════════════════════════════════════════
BCRYPT_SALT_ROUNDS=12

# ══════════════════════════════════════════
# EMAIL (Nodemailer / SMTP)
# ══════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@medicarebi.bj
SMTP_PASS=your_app_password
EMAIL_FROM=MediCare BJ <noreply@medicarebi.bj>

# ══════════════════════════════════════════
# SMS (Africa's Talking)
# ══════════════════════════════════════════
AT_API_KEY=your_africas_talking_key
AT_USERNAME=your_username
AT_SENDER_ID=MediCareBJ

# ══════════════════════════════════════════
# MTN Mobile Money (Bénin)
# ══════════════════════════════════════════
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_api_user_uuid
MTN_API_KEY=your_mtn_api_key
MTN_ENVIRONMENT=sandbox
MTN_CURRENCY=XOF

# ══════════════════════════════════════════
# CinetPay
# ══════════════════════════════════════════
CINETPAY_APIKEY=your_cinetpay_key
CINETPAY_SITE_ID=your_site_id
CINETPAY_SECRET_KEY=your_cinetpay_secret
CINETPAY_NOTIFY_URL=http://localhost:5000/api/v1/paiements/webhook/cinetpay

# ══════════════════════════════════════════
# UPLOADS
# ══════════════════════════════════════════
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads
AVATAR_MAX_SIZE=5242880

# ══════════════════════════════════════════
# LOGS
# ══════════════════════════════════════════
LOG_LEVEL=debug
LOG_FILE=./logs/combined.log

# ══════════════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════════════
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
